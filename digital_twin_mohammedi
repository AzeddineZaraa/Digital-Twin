import subprocess, sys

def install(pkg):
    subprocess.check_call([sys.executable, "-m", "pip", "install", pkg, "-q"])

try:
    import pvlib
except ImportError:
    install("pvlib")

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.dates as mdates
import matplotlib.gridspec as gridspec
import requests
import pvlib
from pvlib import location, irradiance, atmosphere, temperature
from pvlib.location import Location
import warnings
warnings.filterwarnings('ignore')
import os

os.makedirs('digital_twin_mohammedia', exist_ok=True)
print("✓ Librairies chargées")

# ════════════════════════════════════════════════════════════════════
# 1. PARAMÈTRES DU SITE — MOHAMMEDIA
# ════════════════════════════════════════════════════════════════════
LAT       = 33.6861
LON       = -7.3833
ALTITUDE  = 15          # m (ville côtière sur l'Atlantique)
TIMEZONE  = 'Africa/Casablanca'
SITE_NAME = 'Mohammedia, Maroc'

# Panneau : Cell Amrecan OS-P72-330W (inchangé)
TILT          = 31       # inclinaison (°) — optimale pour latitude ~33°
AZIMUTH       = 180      # plein sud
SURFACE       = 1.939    # m² par panneau
EFF_STC       = 0.170    # rendement à STC (17 %)
NB_PANELS     = 12
GAMMA_PMAX    = -0.0040  # coeff thermique (%/°C)
T_STC         = 25.0
EFF_SYSTEME   = 0.65     # rendement BOS + onduleur

Pnom = NB_PANELS * SURFACE * EFF_STC * 1000   # Puissance nominale (W)

print(f"✓ Site         : {SITE_NAME}")
print(f"  Latitude     : {LAT}° N")
print(f"  Longitude    : {LON}° E")
print(f"  Altitude     : {ALTITUDE} m")
print(f"  Pnom         : {Pnom:.0f} W  ({NB_PANELS} panneaux × 330 W)")

# ════════════════════════════════════════════════════════════════════
# 2. LECTURE OPTIONNELLE DU FICHIER CSV LOCAL
#    (si absent → on utilise uniquement Open-Meteo)
# ════════════════════════════════════════════════════════════════════
CSV_PATH = 'fichier.csv'      # ← modifiez ce chemin si nécessaire
BIAIS_CORRECTION = 48.0

df_local = None
if os.path.exists(CSV_PATH):
    try:
        df_raw = pd.read_csv(
            CSV_PATH, sep=';', skiprows=2,
            header=None, na_values=['---']
        )
        df_local = df_raw[[0, 1, 2, 5, 7, 19]].copy()
        df_local.columns = ['Date', 'Heure', 'Temp', 'Hum', 'Vent', 'GHI']
        df_local['Datetime'] = pd.to_datetime(
            df_local['Date'] + ' ' + df_local['Heure'],
            format='%d/%m/%Y %H:%M'
        )
        for c in ['Temp', 'Hum', 'Vent', 'GHI']:
            df_local[c] = pd.to_numeric(df_local[c], errors='coerce')
        df_local['GHI'] = (df_local['GHI'] + BIAIS_CORRECTION).clip(lower=0)
        df_local = df_local.sort_values('Datetime').set_index('Datetime')
        print(f"\n✓ CSV local chargé et corrigé (+{BIAIS_CORRECTION} W/m²)")
    except Exception as e:
        print(f"⚠ CSV ignoré ({e}) — Open-Meteo seul utilisé")
        df_local = None
else:
    print(f"\n⚠ Fichier '{CSV_PATH}' introuvable — Open-Meteo seul utilisé")

# ════════════════════════════════════════════════════════════════════
# 3. TÉLÉCHARGEMENT OPEN-METEO (Mohammedia)
# ════════════════════════════════════════════════════════════════════
DATE_START = "2024-01-01"
DATE_END   = "2024-12-31"

print(f"\nTéléchargement Open-Meteo ({DATE_START} → {DATE_END})…")
url = "https://archive-api.open-meteo.com/v1/archive"
params = {
    "latitude":   LAT,
    "longitude":  LON,
    "start_date": DATE_START,
    "end_date":   DATE_END,
    "hourly": (
        "shortwave_radiation,direct_normal_irradiance,"
        "diffuse_radiation,temperature_2m,windspeed_10m"
    ),
    "timezone": TIMEZONE
}
resp = requests.get(url, params=params, timeout=60)
resp.raise_for_status()
data = resp.json()

df_web = pd.DataFrame({
    'GHI_web':  data['hourly']['shortwave_radiation'],
    'DNI_web':  data['hourly']['direct_normal_irradiance'],
    'DHI_web':  data['hourly']['diffuse_radiation'],
    'Temp_web': data['hourly']['temperature_2m'],
    'Vent_web': data['hourly']['windspeed_10m'],
}, index=pd.to_datetime(data['hourly']['time']))
df_web.index.name = 'Datetime'
# Supprimer timezone pour cohérence avec les données locales
df_web.index = df_web.index.tz_localize(None)

print(f"✓ Open-Meteo : {len(df_web)} heures téléchargées")

# ════════════════════════════════════════════════════════════════════
# 4. FUSION — LOCAL PRIORITAIRE, OPEN-METEO POUR LES LACUNES
# ════════════════════════════════════════════════════════════════════
idx_complet = pd.date_range(DATE_START, f"{DATE_END} 23:00", freq='1h')
df_final = pd.DataFrame(index=idx_complet)
df_final.index.name = 'Datetime'

if df_local is not None:
    df_h = df_local[['Temp', 'Hum', 'Vent', 'GHI']].resample('1h').mean()
    df_final['GHI']  = df_h['GHI'].reindex(df_final.index).fillna(df_web['GHI_web'])
    df_final['Temp'] = df_h['Temp'].reindex(df_final.index).fillna(df_web['Temp_web'])
    df_final['Vent'] = df_h['Vent'].reindex(df_final.index).fillna(df_web['Vent_web'])
    df_final['source'] = np.where(
        df_h['GHI'].reindex(df_final.index).notna(), 'Station', 'Open-Meteo'
    )
else:
    df_final['GHI']    = df_web['GHI_web'].reindex(df_final.index)
    df_final['Temp']   = df_web['Temp_web'].reindex(df_final.index)
    df_final['Vent']   = df_web['Vent_web'].reindex(df_final.index)
    df_final['source'] = 'Open-Meteo'

df_final['DNI'] = df_web['DNI_web'].reindex(df_final.index)
df_final['DHI'] = df_web['DHI_web'].reindex(df_final.index)
df_final = df_final.dropna(subset=['GHI', 'DNI', 'DHI'])

print(f"\n✓ Série fusionnée : {len(df_final)} heures")
print(f"  Station locale  : {(df_final['source']=='Station').sum()} h")
print(f"  Open-Meteo      : {(df_final['source']=='Open-Meteo').sum()} h")

# ════════════════════════════════════════════════════════════════════
# 5. POSITION SOLAIRE ET RAYONNEMENT POA (Mohammedia)
# ════════════════════════════════════════════════════════════════════
site = Location(
    latitude=LAT,
    longitude=LON,
    tz=TIMEZONE,
    altitude=ALTITUDE,
    name=SITE_NAME
)

# Ajouter timezone pour pvlib
idx_tz = df_final.index.tz_localize(TIMEZONE, ambiguous='infer', nonexistent='shift_forward')

solar_pos = site.get_solarposition(idx_tz)
solar_pos.index = df_final.index   # Retirer tz pour l'alignement

dni_extra = irradiance.get_extra_radiation(df_final.index)

poa = irradiance.get_total_irradiance(
    surface_tilt=TILT,
    surface_azimuth=AZIMUTH,
    solar_zenith=solar_pos['apparent_zenith'],
    solar_azimuth=solar_pos['azimuth'],
    dni=df_final['DNI'],
    ghi=df_final['GHI'],
    dhi=df_final['DHI'],
    dni_extra=dni_extra,
    model='perez'
)
df_final['POA'] = poa['poa_global'].clip(lower=0)
print(f"\n✓ Rayonnement POA calculé (modèle Perez, tilt={TILT}°, azimuth={AZIMUTH}°)")

# ════════════════════════════════════════════════════════════════════
# 6. TEMPÉRATURE DU MODULE (modèle Faiman)
# ════════════════════════════════════════════════════════════════════
df_final['T_module'] = temperature.faiman(
    poa_global=df_final['POA'],
    temp_air=df_final['Temp'],
    wind_speed=df_final['Vent']
)
print("✓ Température module calculée (modèle Faiman)")

# ════════════════════════════════════════════════════════════════════
# 7. MODÈLE PV — PUISSANCE DC / AC
# ════════════════════════════════════════════════════════════════════
df_final['P_DC'] = (
    df_final['POA'] / 1000
    * Pnom
    * (1 + GAMMA_PMAX * (df_final['T_module'] - T_STC))
).clip(lower=0)

df_final['P_AC'] = (df_final['P_DC'] * EFF_SYSTEME).clip(lower=0)

df_final['Pertes_thermiques_pct'] = (
    GAMMA_PMAX * (df_final['T_module'] - T_STC) * 100
).clip(upper=0)

# ════════════════════════════════════════════════════════════════════
# 8. ÉNERGIE JOURNALIÈRE ET INDICATEURS DE PERFORMANCE
# ════════════════════════════════════════════════════════════════════
daily = df_final.resample('1D').agg(
    E_kWh         =('P_AC',                  lambda x: x.sum() / 1000),
    GHI_moy       =('GHI',                   'mean'),
    POA_moy       =('POA',                   'mean'),
    T_moy         =('Temp',                  'mean'),
    T_mod_moy     =('T_module',              'mean'),
    T_mod_max     =('T_module',              'max'),
    P_max         =('P_AC',                  'max'),
    Pertes_th_moy =('Pertes_thermiques_pct', 'mean'),
    source        =('source',                'first')
).dropna(subset=['E_kWh'])

daily['E_theorique'] = (daily['POA_moy'] * 24 / 1000) * (Pnom / 1000)
daily['PR']  = (daily['E_kWh'] / daily['E_theorique'].replace(0, np.nan)).clip(0, 1)
daily['Ys']  = daily['E_kWh'] / (Pnom / 1000)   # heures équivalentes

# Agrégation mensuelle
monthly = daily.resample('ME').agg(
    E_kWh    =('E_kWh',  'sum'),
    PR_moy   =('PR',     'mean'),
    T_moy    =('T_moy',  'mean'),
    T_mod_moy=('T_mod_moy','mean'),
    Ys_moy   =('Ys',     'mean'),
)
monthly.index = monthly.index.strftime('%b %Y')

print(f"\n✓ Énergie et PR calculés")
print(f"  Énergie totale annuelle : {daily['E_kWh'].sum():.1f} kWh")
print(f"  PR moyen                : {daily['PR'].mean()*100:.1f} %")
print(f"  Ys moyen                : {daily['Ys'].mean():.2f} h/j")

# ════════════════════════════════════════════════════════════════════
# 9. DÉTECTION D'ANOMALIES (±2σ sur le PR)
# ════════════════════════════════════════════════════════════════════
pr_moy = daily['PR'].mean()
pr_std = daily['PR'].std()
SEUIL_BAS  = pr_moy - 2 * pr_std
SEUIL_HAUT = pr_moy + 2 * pr_std

daily['anomalie'] = (
    ((daily['PR'] < SEUIL_BAS) | (daily['PR'] > SEUIL_HAUT))
    & (daily['POA_moy'] > 50)
)
n_anomalies = int(daily['anomalie'].sum())
print(f"\n✓ Anomalies détectées : {n_anomalies} jours")
print(f"  Seuil bas  : PR < {SEUIL_BAS*100:.1f} %")
print(f"  Seuil haut : PR > {SEUIL_HAUT*100:.1f} %")

