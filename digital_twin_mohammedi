ax3.plot(daily.index, daily['T_mod_moy'], color=RED,    lw=1.2, alpha=0.9, label='Temp. module moy. (°C)')
ax3.plot(daily.index, daily['T_mod_max'], color=AMBER,  lw=0.8, ls='--', alpha=0.7, label='Temp. module max (°C)')
ax3.set_ylabel('Température (°C)', color=MUTED)
