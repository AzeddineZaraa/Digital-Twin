ax2.set_ylabel('PR (%)', color=MUTED)
ax2.set_title('Performance Ratio journalier', color=TEXT, fontsize=11, pad=6)
ax2.legend(fontsize=9, facecolor=PANEL_BG, edgecolor=BORDER, labelcolor=TEXT)
